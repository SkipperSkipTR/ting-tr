<Window x:Class="TingTR_Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TING Türkçe Yama Yükleyici"
        Height="445" Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="There Is No Game: Wrong Dimension"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#e94560"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1"
                   Text="Türkçe Yama Kurulum Aracı"
                   FontSize="14"
                   Foreground="#a0a0b0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="2"
                Background="#16213e"
                BorderBrush="#0f3460"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="StatusText"
                               Text="Yükleniyor..."
                               FontSize="13"
                               Foreground="#e0e0e0"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="GamePathText"
                               Text="Oyun konumu: Tespit edilemedi"
                               FontSize="11"
                               Foreground="#a0a0b0"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <Button x:Name="SelectFolderBtn"
                            Content="Oyun Klasorunu Sec"
                            Height="36"
                            Background="#0f3460"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,10"
                            Visibility="Collapsed"
                            Click="SelectFolderBtn_Click"/>

                    <ProgressBar x:Name="InstallProgress"
                                 Height="20"
                                 Value="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Background="#0f3460"
                                 Foreground="#e94560"
                                 BorderThickness="0"
                                 Margin="0,0,0,10"/>

                    <TextBlock x:Name="ProgressText"
                               Text="Hazır"
                               FontSize="11"
                               Foreground="#a0a0b0"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="InstallBtn"
                                Content="Kur"
                                Width="120"
                                Height="40"
                                Background="#e94560"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                Click="InstallBtn_Click"/>
                        <Button x:Name="UninstallBtn"
                                Content="Kaldır"
                                Width="120"
                                Height="40"
                                Background="#533d4d"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Click="UninstallBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="5"
                   Text="There Is No Game - Wrong Dimension Türkçe Yama"
                   FontSize="10"
                   Foreground="#606070"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>